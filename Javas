// 3. FUNCIONES PRINCIPALES
// Cargar productos en la página
function cargarProductos() {
    elementosDOM.contenedorProductos.innerHTML = "";
    PRODUCTOS.forEach(producto => {
        const tarjeta = document.createElement('div');
        tarjeta.className = 'producto-card';
        tarjeta.innerHTML = `
            <img class="producto-imagen" src="${producto.imagen}" alt="${producto.nombre}">
            <h3>${producto.nombre}</h3>
            <p class="producto-precio">$${producto.precio.toLocaleString('es-CO')} COP</p>
            <p class="producto-descripcion">${producto.descripcion}</p>
            <button class="agregar-carrito" data-id="${producto.id}">Agregar al Carrito</button>
        `;
        elementosDOM.contenedorProductos.appendChild(tarjeta);
    });
    asignarEventosBotonesProductos();
}

// Asignar eventos a botones de "Agregar al Carrito"
function asignarEventosBotonesProductos() {
    document.querySelectorAll('.agregar-carrito').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const idProducto = parseInt(e.target.dataset.id);
            agregarProductoAlCarrito(idProducto);
        });
    });
}

// Agregar producto al carrito
function agregarProductoAlCarrito(idProducto) {
    const productoEncontrado = PRODUCTOS.find(p => p.id === idProducto);
    const productoEnCarrito = carrito.find(item => item.id === idProducto);

    if (productoEnCarrito) {
        productoEnCarrito.cantidad += 1;
    } else {
        carrito.push({ ...productoEncontrado, cantidad: 1 });
    }

    actualizarVisualizacionCarrito();
    guardarCarritoEnLocalStorage();
    mostrarNotificacion(`✅ ${productoEncontrado.nombre} agregado al carrito`);
}

// Actualizar lo que ve el usuario del carrito
function actualizarVisualizacionCarrito() {
    // Actualizar contador en el botón
    const totalItems = carrito.reduce((total, item) => total + item.cantidad, 0);
    elementosDOM.contadorCarrito.textContent = totalItems;

    // Actualizar lista de productos en el modal
    elementosDOM.listaCarrito.innerHTML = "";
    let totalPagar = 0;

    carrito.forEach(item => {
        const subtotal = item.precio * item.cantidad;
        totalPagar += subtotal;

        const elementoItem = document.createElement('div');
        elementoItem.className = 'item-carrito';
        elementoItem.innerHTML = `
            <div>
                <span>${item.nombre}</span> - $${item.precio.toLocaleString('es-CO')} x ${item.cantidad}
            </div>
            <div>$${subtotal.toLocaleString('es-CO')}</div>
        `;
        elementosDOM.listaCarrito.appendChild(elementoItem);
    });

    elementosDOM.totalCarrito.textContent = totalPagar.toLocaleString('es-CO');
}

// Guardar carrito en el navegador (no se pierde al cerrar la página)
function guardarCarritoEnLocalStorage() {
    localStorage.setItem('carritoVivaTeam', JSON.stringify(carrito));
}

// Enviar pedido por WhatsApp
function enviarPedidoPorWhatsapp() {
    const nombre = elementosDOM.nombreCliente.value.trim();
    const correo = elementosDOM.correoCliente.value.trim();
    const direccion = elementosDOM.direccionCliente.value.trim();
    const nit = elementosDOM.nitCliente.value.trim();

    if (!nombre || !correo || !direccion || !nit || carrito.length === 0) {
        mostrarNotificacion("⚠️ Completa todos los datos y agrega productos al carrito");
        return;
    }

    let mensaje = `*${CONFIGURACION.nombreTienda} - NUEVO PEDIDO*\n\n`;
    mensaje += `📋 Datos del Cliente:\n`;
    mensaje += `- Nombre: ${nombre}\n`;
    mensaje += `- Correo: ${correo}\n`;
    mensaje += `- Dirección: ${direccion}\n`;
    mensaje += `- NIT/Cédula: ${nit}\n\n`;
    mensaje += `🛒 Productos:\n`;

    carrito.forEach(item => {
        mensaje += `- ${item.nombre}: ${item.cantidad} unidad(es) - $${(item.precio * item.cantidad).toLocaleString('es-CO')}\n`;
    });

    mensaje += `\n💵 Total a Pagar: $${elementosDOM.totalCarrito.textContent} COP\n`;
    mensaje += `---\nPor favor confirmar pedido y detalles de entrega.`;

    const urlWhatsapp = `https://wa.me/${CONFIGURACION.numeroWhatsapp.replace(/\s/g, "")}?text=${encodeURIComponent(mensaje)}`;
    window.open(urlWhatsapp, '_blank');
}

